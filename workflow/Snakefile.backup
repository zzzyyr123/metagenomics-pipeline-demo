"""
宏基因组分析完整流程 (适配单端数据)
Author: Yiran Zhao
Date: 2026-03-04
数据来源: HUMAnN GitHub示例 (demo.fastq)
"""

# 配置参数
SAMPLE = "demo"
THREADS = 2

# 规则1：最终目标
rule all:
    input:
        "results/metaphlan/demo_profile.txt",
        "results/downstream/top_pathways.txt",
        "results/downstream/alpha_diversity.txt",
        "results/downstream/visualization.Rout"

# ====================== 上游分析 ======================

# 规则2：fastp质控（单端版本）
rule fastp_qc:
    input:
        r1 = f"data/raw/{SAMPLE}_1.fastq"  # 注意：这里用的是软链接
    output:
        r1_clean = "results/fastp/demo.clean.fastq",
        json = "results/fastp/fastp.json",
        html = "results/fastp/fastp_report.html"
    threads: THREADS
    conda:
        "envs/fastp.yaml" 
    resources:
        mem_mb=2000,
        runtime=10
        shell
        """
        fastp -i {input.r1} \
              -o {output.r1_clean} \
              -j {output.json} -h {output.html} \
              -w {threads}
        """

# 规则3：MetaPhlAn物种组成分析（单端版本）
rule metaphlan:
    input:
        clean_reads = "results/fastp/demo.clean.fastq"
    output:
        profile = "results/metaphlan/demo_profile.txt",
        sam = "results/metaphlan/demo_bowtie2.sam.bz2"
    threads: THREADS
    conda:
        "envs/metaphlan.yaml"   
    resources:
        mem_mb=4000,
        runtime=20
        shell
        """
        metaphlan {input.clean_reads} \
                  --input_type fastq \
                  -o {output.profile} \
                  --bowtie2out {output.sam} \
                  --nproc {threads} \
                  --unclassified_estimation
        """

# 规则4：HUMAnN功能通路分析（单端版本）
rule humann:
    input:
        clean_reads = "results/fastp/demo.clean.fastq"
    output:
        pathabundance = "results/humann/demo_pathabundance.tsv",
        genefamilies = "results/humann/demo_genefamilies.tsv",
        pathcoverage = "results/humann/demo_pathcoverage.tsv"
    threads: THREADS
    conda:
        "envs/humann.yaml"   
    resources:
        mem_mb=8000,
        runtime=30
        shell
        """
        humann --input {input.clean_reads} \
               --output results/humann \
               --threads {threads} \
               --output-basename {SAMPLE} \
               --bypass-nucleotide-index \
               --remove-temp-output
        """

# ====================== 下游分析 ======================

# 规则5：提取Top通路
rule top_pathways:
    input:
        pathabundance = "results/humann/demo_pathabundance.tsv"
    output:
        "results/downstream/top_pathways.txt"
    run:
        shell("""
        echo "Top 10 Metabolic Pathways (by abundance):" > {output}
        echo "========================================" >> {output}
        grep -v "^#" {input.pathabundance} | \
        awk '{{sum = 0; for(i=2;i<=NF;i++) sum+=$i; print $1, sum}}' | \
        sort -k2 -rn | head -10 >> {output}
        """)

# 规则6：计算Alpha多样性
rule alpha_diversity:
    input:
        pathabundance = "results/humann/demo_pathabundance.tsv"
    output:
        "results/downstream/alpha_diversity.txt"
    run:
        shell("""
        echo "Alpha Diversity Metrics:" > {output}
        echo "======================" >> {output}
        grep -v "^#" {input.pathabundance} | \
        awk '{{if(NR==1) {{for(i=2;i<=NF;i++) samples[i]=$i}} else {{for(i=2;i<=NF;i++) if($i>0) count[i]++}}}} END {{for(i=2;i<=length(samples);i++) print samples[i], count[i]}}' >> {output}
        """)

# 规则7：R可视化脚本
rule r_visualization:
    input:
        pathabundance = "results/humann/demo_pathabundance.tsv"
    output:
        "results/downstream/visualization.Rout"
    run:
        shell("""
        Rscript scripts/visualize_results.R {input.pathabundance} > {output} 2>&1
        """)
